---
interface MenuItem {
  id: string
  label: string
  href: string
  accent?: boolean
  badge?: string
}

interface Props {
  variant?: 'header' | 'mobile'
}

const { variant = 'header' } = Astro.props

const menuItems: MenuItem[] = [
  { id: '02', label: 'менторы', href: '#mentors' },
  { id: '03', label: 'встречи', href: '#meets' },
  { id: '04', label: 'тарифы', href: '#tariffs', accent: true, badge: 'от 520 ₽' },
  { id: '05', label: 'вопросы', href: '#FAQ' },
]

const isMobile = variant === 'mobile'
---
<nav class:list={[
  isMobile ? 'flex flex-col gap-6 items-center' : 'flex gap-0.5 md:gap-1 lg:gap-4',
]}>
  {menuItems.map(item => (
    <a
      href={item.href}
      class:list={[
        'group relative flex items-center gap-1.5 transition-colors',
        isMobile ? 'text-3xl sm:text-4xl' : 'px-1.5 py-2 lg:px-3 lg:py-2',
        item.accent ? 'text-accent hover:text-accent/80' : 'text-foreground/70 hover:text-accent',
      ]}
      data-close-menu={isMobile ? 'true' : undefined}
    >
      <span class:list={[
        'font-mono opacity-40 group-hover:opacity-100 transition-opacity',
        isMobile ? 'text-sm' : 'text-[10px] hidden lg:inline',
      ]}>
        [{item.id}]
      </span>
      <span class:list={[
        'font-display uppercase tracking-wide',
        isMobile ? 'text-3xl sm:text-4xl' : 'text-xs lg:text-base',
      ]}>
        {item.label}
      </span>
      {item.badge && (
        <span class:list={[
          'font-mono text-[10px] tracking-wider px-1.5 py-0.5 border border-accent/40 bg-accent/10 text-accent',
          !isMobile && 'hidden lg:inline',
        ]}>
          {item.badge}
        </span>
      )}
      {!isMobile && (
        <span class="absolute left-2 right-2 bottom-0.5 h-px bg-accent scale-x-0 origin-left group-hover:scale-x-100 transition-transform duration-300"></span>
      )}
    </a>
  ))}
</nav>
