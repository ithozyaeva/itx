---
import UiButton from './UiButton.astro'

interface Props {
  name: string
  price: number
  oldPrice?: number
  features: string[]
  link: string
  variant?: 'default' | 'highlighted'
  tierIndex?: string
  tierLabel?: string
  trackTariff?: string
}

const {
  name,
  price,
  oldPrice,
  features,
  link,
  variant = 'default',
  tierIndex,
  tierLabel,
  trackTariff,
} = Astro.props

const discount = (() => {
  if (!oldPrice)
    return null
  if (oldPrice <= 0 || price >= oldPrice)
    return null
  return Math.round((oldPrice - price) * 100 / oldPrice)
})()

const isHighlighted = variant === 'highlighted'
---
<div
  class:list={[
    'price-card group relative flex flex-col border transition-all duration-300',
    isHighlighted
      ? 'bg-accent text-[#0b0d0c] border-accent shadow-[0_30px_80px_-30px_hsl(var(--accent)/0.5)] md:-translate-y-3'
      : 'bg-background/80 text-foreground border-accent/20 hover:border-accent/50',
  ]}
>
  <span class:list={['absolute top-0 left-0 w-3 h-3 border-t-2 border-l-2', isHighlighted ? 'border-[#0b0d0c]' : 'border-accent']}></span>
  <span class:list={['absolute top-0 right-0 w-3 h-3 border-t-2 border-r-2', isHighlighted ? 'border-[#0b0d0c]' : 'border-accent']}></span>
  <span class:list={['absolute bottom-0 left-0 w-3 h-3 border-b-2 border-l-2', isHighlighted ? 'border-[#0b0d0c]' : 'border-accent']}></span>
  <span class:list={['absolute bottom-0 right-0 w-3 h-3 border-b-2 border-r-2', isHighlighted ? 'border-[#0b0d0c]' : 'border-accent']}></span>

  <div class:list={['px-6 md:px-7 pt-6 pb-5 border-b', isHighlighted ? 'border-[#0b0d0c]/15' : 'border-accent/15']}>
    <div class:list={[
      'flex items-center justify-between font-mono text-[11px] tracking-[0.1em] uppercase mb-4',
      isHighlighted ? 'text-[#0b0d0c]/70' : 'text-foreground/50',
    ]}>
      <span>[ уровень.{tierIndex} ]</span>
      {isHighlighted ? <span class="px-2 py-0.5 bg-[#0b0d0c] text-accent">выбор</span> : tierLabel && <span>{tierLabel}</span>}
    </div>
    <h3 class:list={['font-display uppercase text-2xl md:text-3xl leading-tight', isHighlighted ? 'text-[#0b0d0c]' : 'text-accent']}>
      {name}
    </h3>

    <div class="mt-5 flex items-baseline gap-2">
      {oldPrice && (
        <span class:list={['font-mono text-sm line-through', isHighlighted ? 'text-[#0b0d0c]/50' : 'text-foreground/30']}>
          {oldPrice}₽
        </span>
      )}
      <span class:list={['font-display text-4xl md:text-5xl leading-none', isHighlighted ? 'text-[#0b0d0c]' : 'text-foreground']}>
        {price}
      </span>
      <span class:list={['font-display text-2xl md:text-3xl', isHighlighted ? 'text-[#0b0d0c]/80' : 'text-foreground/70']}>
        ₽
      </span>
      <span class:list={['font-mono text-xs self-end pb-1', isHighlighted ? 'text-[#0b0d0c]/60' : 'text-foreground/40']}>
        /мес
      </span>
      {discount && (
        <span class:list={[
          'ml-auto font-mono text-[11px] px-2 py-1 border tracking-wider',
          isHighlighted ? 'border-[#0b0d0c] text-[#0b0d0c]' : 'border-term-amber text-term-amber',
        ]}>
          −{discount}%
        </span>
      )}
    </div>
  </div>

  <ul class="flex-1 px-6 md:px-7 py-6 space-y-3">
    {features.map(feature => (
      <li class:list={[
        'flex items-start gap-3 text-sm md:text-[15px] leading-snug',
        isHighlighted ? 'text-[#0b0d0c]' : 'text-foreground/80',
      ]}>
        <svg
          class:list={['w-4 h-4 mt-0.5 shrink-0', isHighlighted ? 'text-[#0b0d0c]' : 'text-accent']}
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  <div class="px-6 md:px-7 pb-6">
    <UiButton
      as="a"
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      variant={isHighlighted ? 'dark-filled' : 'filled'}
      class="w-full text-center"
      data-track-tariff={trackTariff}
    >
      Подписаться →
    </UiButton>
  </div>
</div>

<style>
.price-card {
  border-radius: 2px;
  min-width: 280px;
  min-height: 480px;
}
.price-card :global(.ui-button) {
  width: 100%;
  border-radius: 2px !important;
}
</style>
