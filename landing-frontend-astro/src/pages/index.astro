---
import MinimalFooter from '@/components/MinimalFooter.astro'
import MinimalHeader from '@/components/MinimalHeader.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { SITE, TARIFFS } from '@/lib/site'

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    'name': SITE.name,
    'url': SITE.url,
    'description': SITE.baseDescription,
  },
]
---
<BaseLayout
  title="IT-ХОЗЯЕВА — ИТ-сообщество с ИИ, менторством и вайбкодингом"
  description={SITE.baseDescription}
  url={SITE.url}
  jsonLd={jsonLd}
>
  <MinimalHeader />
  <main>
    <section class="w-full pt-16 md:pt-24 pb-16">
      <div class="container px-6 md:px-10 max-w-4xl">
        <p class="font-mono text-xs text-foreground/40 mb-6 uppercase tracking-widest">
          ⚠️ wip: astro port — основной лендинг ещё переносится из vue
        </p>
        <h1 class="font-display uppercase text-[40px] md:text-[72px] lg:text-[88px] leading-[0.9] tracking-tight text-accent">
          IT-ХОЗЯЕВА
        </h1>
        <p class="mt-6 md:mt-8 text-base md:text-lg text-foreground/75 leading-relaxed">
          Закрытое ИТ-сообщество 250+ специалистов на стыке технологий и ИИ. Менторство, вайбкодинг,
          нетворкинг, подготовка к собеседованиям, еженедельные онлайн-встречи.
        </p>

        <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-px bg-accent/15 border border-accent/15">
          {Object.values(TARIFFS).map(t => (
            <div class="bg-background/95 p-6 md:p-7">
              <h2 class="font-display uppercase text-lg md:text-xl text-accent mb-2">{t.name}</h2>
              <p class="font-mono text-sm text-foreground/60 mb-3">{t.price} ₽/мес</p>
              <p class="text-sm text-foreground/70 leading-relaxed mb-4">{t.description}</p>
              <a
                href={t.boostyUrl}
                rel="noopener"
                class="inline-block font-mono text-xs uppercase tracking-widest text-accent hover:underline underline-offset-4"
              >
                оформить на boosty →
              </a>
            </div>
          ))}
        </div>

        <div class="mt-12 flex flex-wrap gap-4 font-mono text-sm">
          <a href="/articles" class="text-accent hover:underline underline-offset-4">→ Статьи</a>
          <a href="/mentors" class="text-accent hover:underline underline-offset-4">→ База менторов</a>
          <a href="/vibe-coding" class="text-accent hover:underline underline-offset-4">→ Что такое вайбкодинг</a>
        </div>
      </div>
    </section>
  </main>
  <MinimalFooter />
</BaseLayout>
