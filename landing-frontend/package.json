    "@tanstack/vue-query": "^5.100.9",
    "@unhead/vue": "^2.1.13",
    "@vueuse/core": "^14.3.0",
    "@yeger/vue-masonry-wall": "^6.1.1",
    "axios": "^1.16.0",
    "cva": "npm:class-variance-authority@^0.7.1",
    "lucide-vue-next": "^0.577.0",
    "regl": "^2.1.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.6",
