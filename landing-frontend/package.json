    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
