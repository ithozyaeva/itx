---
type Variant = 'filled' | 'stroke' | 'dark-filled'

interface Props {
  'as'?: 'button' | 'a'
  'href'?: string
  'target'?: string
  'rel'?: string
  'type'?: 'button' | 'submit' | 'reset'
  'variant'?: Variant
  'class'?: string
  'id'?: string
  'data-action'?: string
}

const {
  as = 'button',
  href,
  target,
  rel,
  type,
  variant = 'filled',
  class: className = '',
  id,
  'data-action': dataAction,
  ...rest
} = Astro.props

const Tag = as === 'a' ? 'a' : 'button'
---
<Tag
  class:list={['ui-button', variant, className]}
  href={as === 'a' ? href : undefined}
  target={as === 'a' ? target : undefined}
  rel={as === 'a' ? rel : undefined}
  type={as === 'button' ? (type ?? 'button') : undefined}
  id={id}
  data-action={dataAction}
  {...rest}
>
  <span class="ui-button-text">
    <slot />
  </span>
</Tag>

<style>
.ui-button-text {
  font-family: var(--button-font), sans-serif;
  font-weight: var(--button-weight);
  font-size: var(--button-size);
  line-height: var(--button-line-height);
  letter-spacing: var(--button-letter-spacing);
  text-transform: var(--button-transform);
}

.ui-button {
  border-radius: var(--radius-button);
  color: var(--color-green-black-700);
  transition: var(--transition-default);
  box-sizing: border-box;
  cursor: pointer;
  text-align: center;
  text-decoration: none;
  display: inline-block;
  border: 4px solid transparent;
  align-content: center;
  min-height: 48px;
  padding: 11px 26px;
}

.ui-button.filled {
  background-color: var(--color-green-700);
}
.ui-button.filled:hover {
  background-color: var(--color-white);
}
.ui-button.filled:focus-visible {
  outline: 2px solid var(--color-green-700);
  outline-offset: 2px;
}
.ui-button.filled:active {
  background-color: var(--color-grey);
}

.ui-button.stroke {
  border: 2px solid var(--color-green-700);
  color: var(--color-green-700);
  background-color: transparent;
}
.ui-button.stroke:hover {
  border-color: var(--color-white);
  color: var(--color-white);
}

.ui-button.dark-filled {
  background-color: var(--color-green-black-700);
  color: var(--color-green-700);
}
.ui-button.dark-filled:hover {
  background-color: var(--color-green-black-400);
}
</style>
