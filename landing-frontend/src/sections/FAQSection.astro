---
import SectionHeader from '@/components/ui/SectionHeader.astro'

interface Question {
  title: string
  answer: string
}

const questions: Question[] = [
  {
    title: 'Как вступить в сообщество IT-ХОЗЯЕВА?',
    answer: 'Выберите тариф (Бригадир, ХОЗЯИН или МАСТЕР), оформите подписку на Boosty и получите доступ к закрытой платформе, чатам, базе менторов и всем материалам вашего тарифа. Подписка от 520 ₽/мес.',
  },
  {
    title: 'Можно ли сменить тариф или отменить подписку?',
    answer: 'Да. Тарифный план можно повысить или понизить в любой момент через Boosty. При повышении доплата рассчитывается пропорционально, при понижении — изменения вступают со следующего периода оплаты.',
  },
  {
    title: 'Какие активности проходят в сообществе?',
    answer: 'Еженедельные онлайн-встречи: английский клуб, технический книжный клуб, лекции по архитектуре, ИИ и вайбкодингу (vibe coding). Практические занятия по искусственному интеллекту, нетворкинг-сессии, тренировочные собеседования, разбор резюме, обмен вакансиями и реферальными ссылками.',
  },
  {
    title: 'Для кого подходит IT-ХОЗЯЕВА?',
    answer: 'Для ИТ-специалистов любого уровня и направления: разработчики, ИИ-инженеры, тестировщики, аналитики, DevOps-инженеры, менеджеры. Для тех, кто интересуется искусственным интеллектом, вайбкодингом и хочет расти через менторство и нетворкинг в ИТ-сообществе. Участники из Яндекса, Тинькофф, VK — от начинающих до руководителей.',
  },
]
---
<section id="FAQ" class="w-full py-20 md:py-32 lg:py-40">
  <div class="container px-6 md:px-10">
    <div class="reveal">
      <SectionHeader
        index="05"
        path="~/community/faq.txt"
        title="Частые вопросы"
        subtitle="Ответы на популярные вопросы о сообществе IT-ХОЗЯЕВА."
      />
    </div>

    <div class="mt-12 md:mt-16 border border-accent/20 bg-background/60 backdrop-blur-sm reveal">
      {questions.map((q, i) => (
        <details
          class="faq-item border-b border-accent/15 last:border-b-0 group"
          open={i === 0}
        >
          <summary class="w-full flex items-start gap-4 md:gap-6 text-left px-5 md:px-8 py-5 md:py-7 cursor-pointer list-none transition-colors hover:bg-accent/[0.04]">
            <span class="faq-arrow font-mono text-xs md:text-sm mt-1 shrink-0 transition-transform duration-300 text-accent/60">
              &gt;
            </span>
            <div class="flex-1 flex items-start justify-between gap-4">
              <div class="flex flex-col gap-1.5">
                <span class="font-mono text-[10px] md:text-xs text-foreground/40 tracking-[0.12em]">
                  Q.{String(i + 1).padStart(2, '0')}
                </span>
                <h3 class="faq-title font-display uppercase text-base md:text-lg lg:text-xl leading-tight transition-colors text-foreground group-hover:text-accent">
                  {q.title}
                </h3>
              </div>
              <span
                class="faq-marker font-mono text-xs shrink-0 mt-1 text-foreground/40"
                aria-hidden="true"
              ></span>
            </div>
          </summary>
          <div class="px-5 md:px-8 pb-6 md:pb-8 pl-14 md:pl-[66px]">
            <div class="font-mono text-[11px] text-accent/60 mb-2">
              &gt; answer:
            </div>
            <p class="text-sm md:text-base text-foreground/75 leading-relaxed max-w-3xl">
              {q.answer}
            </p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
.faq-item summary::-webkit-details-marker {
  display: none;
}
.faq-item[open] .faq-arrow {
  color: hsl(var(--accent));
  transform: rotate(90deg);
}
/* Маркер живёт целиком в ::before, чтобы screen reader не зачитывал
   и закрытое, и открытое состояние одновременно (aria-hidden на span). */
.faq-marker::before {
  content: '[+]';
}
.faq-item[open] .faq-marker {
  color: hsl(var(--accent));
}
.faq-item[open] .faq-marker::before {
  content: '[−]';
}
.faq-item[open] .faq-title {
  color: hsl(var(--accent));
}
</style>

<script>
// Один open за раз — закрываем остальные при открытии нового.
document.addEventListener('toggle', (e) => {
  const target = e.target as HTMLDetailsElement
  if (!target.matches('.faq-item') || !target.open)
    return
  document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach((d) => {
    if (d !== target)
      d.open = false
  })
}, true)
</script>
