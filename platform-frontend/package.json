{
  "name": "it-x-platform",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run lint",
    "build": "npm run type-check  && npm run build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@tanstack/vue-query": "^5.100.9",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ky": "^1.14.3",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.6",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite": "8.0.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
